            "data_overrides": {
                "text_inputs": {
                    "firstName": "John",
                    "lastName": "Doe",
                    "email": "john.doe@example.com",
                    "phone": "1234567890"
                },
                "dropdowns": {
                    "country": {
                        "value": "us",
                        "text": "United States"
                    }
                },
                "radio_groups": {
                    "gender": "male",
                    "accountType": "personal"
                },
